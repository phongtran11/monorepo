{
  "name": "@lam-thinh-ecommerce/shared",
  "version": "1.0.0",
  "description": "Shared types, constants, helpers for the monorepo",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "dts-bundle-generator -o dist/index.d.ts src/index.ts && rolldown -c rolldown.config.ts",
    "dev": "dts-bundle-generator -o dist/index.d.ts src/index.ts && rolldown -c rolldown.config.ts --watch",
    "lint": "eslint .",
    "check": "prettier --write . && eslint --fix"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.12.4",
  "devDependencies": {
    "@types/node": "^25.4.0",
    "dts-bundle-generator": "^9.5.1",
    "rolldown": "1.0.0-rc.9"
  }
}
